{
  "name": "nxt-lvl-platform-api",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@10.9.3",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "npx prisma db push --accept-data-loss && node dist/index.js",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "db:backfill:tenant": "node --import tsx src/backfillTenantContext.ts",
    "db:backfill:eventure-participant-company-status": "node --import tsx src/scripts/backfillEventureParticipantCompanyStatus.ts",
    "db:seed:suite-programs": "node --import tsx src/scripts/seedSuitePrograms.ts",
    "db:seed:community-chronicle": "node scripts/seed-community-chronicle-partition.js",
    "db:seed:financial-hub-admin": "node --import tsx src/scripts/seedFinancialHubAdmin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@nxtlvl/notification-core": "file:./packages/notification-core",
    "@prisma/client": "6.19.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/jszip": "^3.4.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.16.5",
    "@types/pdf-parse": "^1.1.5",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "prisma": "6.19.3",
    "resend": "^6.12.2",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.32.0",
    "globals": "^15.15.0",
    "supertest": "^7.2.2",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  }
}
