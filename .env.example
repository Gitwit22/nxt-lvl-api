# Nxt Lvl Platform API
PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@host:5432/community_chronicle

JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=8h

UPLOAD_DIR=./uploads

# Public URL of this API server used when emitting absolute file URLs
BACKEND_URL=http://localhost:4000

# Comma-separated allowed CORS origins. Use * for dev, specific origins for production.
CORS_ORIGIN=*
