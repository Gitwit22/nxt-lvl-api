# Nxt Lvl Platform API
PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@host:5432/community_chronicle

JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=8h
PLATFORM_LAUNCH_TOKEN_SECRET=your-platform-launch-signing-secret
PLATFORM_SETUP_TOKEN=
PLATFORM_API_BASE_URL=
PLATFORM_VALIDATE_LAUNCH_URL=
PLATFORM_AUTH_TIMEOUT_MS=8000

UPLOAD_DIR=./uploads
DEFAULT_ORGANIZATION_ID=default-org
CURRENT_PROGRAM_DOMAIN=community-chronicle

# Public URL of this API server used when emitting absolute file URLs
BACKEND_URL=http://localhost:4000

# Comma-separated allowed CORS origins. Use * for dev, specific origins for production.
CORS_ORIGIN=*

# Document intelligence
DOC_INTEL_API_BASE_URL=
DOC_INTEL_API_TOKEN=
DOC_INTEL_TIMEOUT_MS=60000
ENABLE_DOC_INTEL_CLASSIFY=true
LLAMA_CLOUD_API_KEY=
ENABLE_LLAMA_CLASSIFY=true
LLAMA_CLASSIFY_AUTO_ACCEPT_THRESHOLD=0.85
LLAMA_CLASSIFY_REVIEW_THRESHOLD=0.6
LLAMA_CLASSIFY_POLL_INTERVAL_MS=1500
LLAMA_CLASSIFY_MAX_POLL_ATTEMPTS=40

# Storage backend
STORAGE_BACKEND=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
R2_DEFAULT_PREFIX=
MAX_FILE_SIZE_BYTES=52428800

# Queue / processing thresholds
MAX_QUEUE_ATTEMPTS=3
JOB_TIMEOUT_MS=120000
RETRY_BACKOFF_BASE_MS=5000
SCANNED_PDF_WORDS_PER_PAGE_THRESHOLD=20
OCR_CONFIDENCE_REVIEW_THRESHOLD=0.7
