# ── Backend (Express API) ──────────────────────────────────
PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@host:5432/community_chronicle

JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=8h

UPLOAD_DIR=./uploads

# Public URL of this API server (used for absolute file URLs sent to the frontend)
# In production set to e.g. https://community-chronicle-api.onrender.com
BACKEND_URL=http://localhost:4000

# Comma-separated allowed CORS origins. Use * for dev, specific origins for production.
# Example: https://community-chronicle.pages.dev
CORS_ORIGIN=*

# ── Frontend (Vite build-time) ─────────────────────────────
# Set in Cloudflare Pages environment settings when the API is deployed:
# VITE_API_BASE_URL=https://community-chronicle-api.onrender.com/api