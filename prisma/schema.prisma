generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  organizationId String @default("default-org")
  email        String   @unique
  passwordHash String   @default("")
  role         String   @default("uploader")
  displayName  String   @default("")
  firstName    String   @default("")
  lastName     String   @default("")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  identitySource String  @default("local")   // "platform" | "local"
  platformUserId String?                      // nullable – the Suite user ID for platform-linked users

  createdDocuments  Document[] @relation("CreatedBy")
  uploadedDocuments Document[] @relation("UploadedBy")
  reviewedDocuments Document[] @relation("ReviewedBy")
  memberships       Membership[] @relation("UserMembers")

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([identitySource])
  @@index([platformUserId])
}

model Organization {
  id                String    @id @default(cuid())
  name              String
  slug              String    @unique
  subdomain         String?
  contactEmail      String?
  ownerEmail        String?
  supportEmail      String?
  phoneNumber       String?
  industryType      String?
  notes             String?
  logoUrl           String?
  bannerUrl         String?
  primaryColor      String?
  accentColor       String?
  assignedBundleIds Json      @default("[]")
  assignedProgramIds Json     @default("[]")
  planType          String    @default("starter")
  status            String    @default("active")
  seatLimit         Int       @default(25)
  trialEndsAt       DateTime?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  members Membership[] @relation("OrgMembers")

  @@index([isActive])
  @@index([status])
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           String   @default("member")
  createdAt      DateTime @default(now())

  user         User         @relation("UserMembers", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation("OrgMembers", fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Program {
  id               String   @id @default(cuid())
  programDomain    String   @default("community-chronicle")
  organizationId   String?
  slug             String
  name             String
  shortDescription String
  longDescription  String   @default("")
  category         String   @default("General")
  tags             Json
  status           String
  type             String
  origin           String   @default("suite-native")
  internalRoute    String?
  externalUrl      String?
  openInNewTab     Boolean  @default(false)
  logoUrl          String?
  screenshotUrl    String?
  accentColor      String?
  isFeatured       Boolean  @default(false)
  isPublic         Boolean  @default(true)
  requiresLogin    Boolean  @default(false)
  requiresApproval Boolean  @default(false)
  launchLabel      String   @default("Launch")
  displayOrder     Int      @default(999)
  notes            String   @default("")
  authMode         String   @default("local_only")  // "platform_only" | "local_only" | "hybrid"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  @@unique([programDomain, slug])
  @@index([programDomain, deletedAt, displayOrder])
  @@index([programDomain, organizationId])
}

model Document {
  id                    String    @id
  organizationId        String    @default("default-org")
  programDomain         String    @default("community-chronicle")
  title                 String
  description           String    @default("")
  author                String    @default("Unknown")
  year                  Int
  month                 Int?
  category              String
  type                  String
  financialCategory     String?
  financialDocumentType String?
  tags                  Json
  keywords              Json
  originalFileName      String?
  mimeType              String?
  fileSize              Int?
  fileUrl               String
  filePath              String?
  processingStatus      String
  ocrStatus             String
  extractedText         String    @default("") @db.Text
  extractedMetadata     Json
  classificationResult  Json?
  intakeSource          String
  sourceReference       String?
  department            String?
  createdAt             DateTime
  updatedAt             DateTime  @updatedAt
  importedAt            DateTime
  processingHistory     Json
  status                String?
  statusUpdatedAt       DateTime?
  auditTrail            Json?
  extraction            Json?
  duplicateCheck        Json?
  review                Json?
  searchIndex           Json?
  needsReview           Boolean   @default(false)
  aiSummary             String    @default("") @db.Text

  createdByUserId String?
  uploadedById  String?
  reviewedById  String?
  createdBy     User?   @relation("CreatedBy", fields: [createdByUserId], references: [id])
  uploadedBy    User?   @relation("UploadedBy", fields: [uploadedById], references: [id])
  reviewedBy    User?   @relation("ReviewedBy", fields: [reviewedById], references: [id])

  jobs ProcessingJob[]

  @@index([organizationId, programDomain, createdAt])
  @@index([organizationId, programDomain, needsReview, updatedAt])
}

model ProcessingJob {
  id          String    @id @default(cuid())
  organizationId String @default("default-org")
  programDomain  String @default("community-chronicle")
  documentId  String
  status      String    @default("queued")
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  error       String?
  errorLog    Json?
  scheduledAt DateTime  @default(now())
  nextRetryAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([documentId])
  @@index([organizationId, programDomain, status, scheduledAt])
}
