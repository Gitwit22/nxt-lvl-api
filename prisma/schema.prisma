model Document {
  id                    String    @id
  organizationId        String
  programDomain         String
  parentDocumentId      String?
  rootDocumentId        String?
  isVirtualSegment      Boolean   @default(false)
  segmentIndex          Int?
  segmentPageStart      Int?
  segmentPageEnd        Int?
  segmentConfidence     Float?
  splitReviewRequired   Boolean   @default(false)
  segmentationStatus    String?
  title                 String
  description           String    @default("")
  author                String    @default("Unknown")
  year                  Int
  month                 Int?
  category              String
  type                  String
  financialCategory     String?
  financialDocumentType String?
  tags                  Json
  keywords              Json
  originalFileName      String?
  mimeType              String?
  fileSize              Int?
  fileUrl               String
  filePath              String?
  processingStatus      String
  ocrStatus             String
  extractedText         String    @default("") @db.Text
  extractedMetadata     Json
  classificationResult  Json?
  intakeSource          String
  sourceReference       String?
  department            String?
  createdAt             DateTime
  updatedAt             DateTime  @updatedAt
  importedAt            DateTime
  processingHistory     Json
  status                String?
  statusUpdatedAt       DateTime?
  auditTrail            Json?
  extraction            Json?
  duplicateCheck        Json?
  review                Json?
  searchIndex           Json?
  needsReview           Boolean   @default(false)
  aiSummary             String    @default("") @db.Text

  // ── Lightweight search-first metadata (Phase 2 refactor) ─────────────────
  // documentType: canonical type key (invoice | receipt | letter | form |
  //   sign_in_sheet | business_card | report | notice | other_unclassified | custom)
  documentType          String?
  // sourceName: who issued / sent the document (org name, person, agency)
  sourceName            String?
  // documentDate: ISO date string extracted from document content
  documentDate          String?
  // Structured entity arrays extracted from document text
  metaPeople            Json?     // string[]
  metaCompanies         Json?     // string[]
  metaLocations         Json?     // string[]
  metaReferenceNumbers  Json?     // string[]
  metaOther             Json?     // string[] — anything useful that doesn't fit buckets
  // classificationStatus: known | other_unclassified | reviewed_mapped | promoted_custom_type
  classificationStatus  String?
  // classificationMatchedBy: rule | keyword | source | similarity | manual
  classificationMatchedBy String?
  // classificationConfidence: 0–1 float
  classificationConfidence Float?
  // reviewRequired: true when type is other_unclassified or confidence is low
  reviewRequired        Boolean   @default(false)

  createdByUserId String?
  uploadedById  String?
  reviewedById  String?
  parentDocument Document? @relation("DocumentSegments", fields: [parentDocumentId], references: [id], onDelete: SetNull)
  childSegments  Document[] @relation("DocumentSegments")
  createdBy     User?   @relation("CreatedBy", fields: [createdByUserId], references: [id])
  uploadedBy    User?   @relation("UploadedBy", fields: [uploadedById], references: [id])
  reviewedBy    User?   @relation("ReviewedBy", fields: [reviewedById], references: [id])

  links DocumentLink[]
  jobs ProcessingJob[]
  pageFeatures ChroniclePdfPageFeature[]
  boundaryDecisions ChroniclePdfBoundaryDecision[]

  @@index([organizationId, programDomain, createdAt])
  @@index([organizationId, programDomain, needsReview, updatedAt])
  @@index([organizationId, programDomain, documentType])
  @@index([organizationId, programDomain, classificationStatus])
  @@index([organizationId, programDomain, reviewRequired, updatedAt])
  @@index([organizationId, programDomain, parentDocumentId])
  @@index([organizationId, programDomain, rootDocumentId])
  @@index([organizationId, programDomain, splitReviewRequired, updatedAt])
}

// ─── Finance Hub: Payee & Tax Identity Management ────────────────────────────

model Payee {
  id                    String   @id @default(cuid())
  organizationId        String
  payeeType             String   // w2_employee | contractor_1099 | vendor_business | volunteer | board_member | stipend_honorarium_recipient | reimbursement_only

  legalName             String
  businessName          String?
  dbaName               String?
  preferredName         String?

  address               String?
  phone                 String?
  email                 String?

  startDate             DateTime?
  endDate               DateTime?
  employmentStatus      String?  // active | inactive | terminated

  relationshipType      String?  // board | volunteer | intern | community_partner | participant
  jobTitle              String?
  department            String?
  program               String?
  supervisor            String?

  compensationModel     String?  // hourly | salary | stipend | project | flat_fee | reimbursement_only
  payRate               Float?
  payFrequency          String?
  standardHours         Float?
  fteStatus             String?

  w4Status              String?  // received | missing | not_required
  w9Status              String?  // received | missing | not_required
  directDepositStatus   String?  // received | missing | not_required
  is1099Eligible        String?  // yes | no | unknown
  benefitsEligible      String?  // yes | no | unknown

  insuranceDeductionAmount Float?
  retirementDeductionAmount Float?
  insuranceCertificateStatus String?  // received | missing | not_required

  paymentTerms          String?
  serviceCategory       String?
  emergencyContact      String?
  notes                 String?

  eligiblePaymentTypes  String[] // reimbursement | stipend | mileage | gift_card | honorarium
  uploadedDocuments     String[] // w4 | i9 | id_or_license | w9 | contract | etc.

  hasTaxIdentity        Boolean  @default(false)
  taxIdStatus           String?  // collected | verified | needs_correction | missing

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  createdByUserId       String?
  updatedByUserId       String?

  secureTaxIdentity     PayeeSecureTaxIdentity?
  auditLogs             AuditLog[]

  @@index([organizationId])
  @@index([organizationId, payeeType])
  @@index([organizationId, employmentStatus])
  @@index([organizationId, hasTaxIdentity])
}

model PayeeSecureTaxIdentity {
  id                    String   @id @default(cuid())
  organizationId        String
  payeeId               String   @unique
  
  taxIdType             String   // SSN | EIN | ITIN | UNKNOWN
  encryptedTaxId        String   @db.Text
  taxIdLast4            String   // Last 4 digits for display, e.g., "1234"
  taxIdHash             String   // SHA-256 hash of formatted tax ID for duplicate detection (never exposed)
  
  taxIdStatus           String   // Missing | Collected | Verified | Needs correction
  taxIdVerifiedAt       DateTime?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  createdByUserId       String
  updatedByUserId       String

  payee                 Payee    @relation(fields: [payeeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, payeeId])
  @@index([organizationId, taxIdHash])
}

model AuditLog {
  id                    String   @id @default(cuid())
  organizationId        String
  payeeId               String
  
  action                String   // tax_id_created | tax_id_updated | tax_id_revealed | tax_id_deleted | tax_id_verification_status_changed
  actionType            String   // CREATE | UPDATE | READ | DELETE
  
  userId                String   // User who performed the action
  userEmail             String?
  
  details               Json?    // Additional context about the action
  ipAddress             String?
  userAgent             String?
  
  createdAt             DateTime @default(now())

  payee                 Payee    @relation(fields: [payeeId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, payeeId])
  @@index([organizationId, action, createdAt])
  @@index([userId, createdAt])
}

model DocumentLink {
  id             String   @id @default(cuid())
  organizationId String
  programDomain  String
  documentId     String
  entityType     String
  entityId       String
  linkType       String   @default("attachment")
  notes          String?
  sourceContext  String?
  createdByUserId String?
  createdAt      DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([organizationId, programDomain, documentId, entityType, entityId, linkType])
  @@index([organizationId, programDomain, documentId])
  @@index([organizationId, programDomain, entityType, entityId], map: "DocumentLink_orgId_domain_entityType_entityId_idx")
  @@index([organizationId, programDomain, entityType, entityId, linkType], map: "DocumentLink_orgId_domain_entityType_entityId_linkType_idx")
}

// ── Community Chronicle: document type registry ───────────────────────────────
// Stores both system-defined and admin-created document types.
model ChronicleDocumentType {
  id            String    @id @default(cuid())
  organizationId String
  programDomain  String   @default("community-chronicle")
  key           String    // e.g. "invoice", "receipt", "my_custom_type"
  label         String    // Human-readable label
  description   String    @default("")
  isSystemType  Boolean   @default(false)  // true = shipped with the system
  isUserCreated Boolean   @default(false)  // true = admin promoted from other_unclassified
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  fingerprint   ChronicleTypeFingerprint?

  @@unique([organizationId, programDomain, key])
  @@index([organizationId, programDomain, active])
}

// ── Community Chronicle: type fingerprints for learned classification ─────────
// Stores phrases, company names, and patterns discovered during admin review
// of other_unclassified documents.  Used to improve future classifications.
model ChronicleTypeFingerprint {
  id             String   @id @default(cuid())
  documentTypeId String   @unique
  phrases        Json     @default("[]")   // string[] — distinctive phrases
  companies      Json     @default("[]")   // string[] — known issuers
  filenamePatterns Json   @default("[]")   // string[] — filename regex patterns
  datePatterns   Json     @default("[]")   // string[] — date format hints
  sampleDocumentIds Json  @default("[]")   // string[] — doc IDs used as examples
  updatedAt      DateTime @updatedAt

  documentType ChronicleDocumentType @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)
}

model ProcessingJob {
  id             String    @id @default(cuid())
  organizationId String
  programDomain  String
  documentId  String
  status      String    @default("queued")
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  error       String?
  errorLog    Json?
  scheduledAt DateTime  @default(now())
  nextRetryAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([documentId])
  @@index([organizationId, programDomain, status, scheduledAt])
}

model ChroniclePdfPageFeature {
  id               String   @id @default(cuid())
  organizationId   String
  programDomain    String
  documentId       String
  pageIndex        Int
  topLines         Json     @default("[]")
  bottomLines      Json     @default("[]")
  headerTitle      String?
  identifierTokens Json     @default("[]")
  pageNumberCue    Json?
  templateSignature String?
  layoutHints      Json     @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, pageIndex])
  @@index([organizationId, programDomain, documentId])
}

model ChroniclePdfBoundaryDecision {
  id                String   @id @default(cuid())
  organizationId    String
  programDomain     String
  documentId        String
  leftPageIndex     Int
  rightPageIndex    Int
  continuationScore Float
  boundaryScore     Float
  confidence        Float
  decision          String
  reasons           Json     @default("[]")
  evidence          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, leftPageIndex, rightPageIndex])
  @@index([organizationId, programDomain, documentId])
}
