  status           String    @default("pending")   // pending | accepted | revoked | expired
  emailStatus      String    @default("not_sent")  // not_sent | sent | failed
  acceptedAt       DateTime?
  revokedAt        DateTime?
  resentAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([organizationId, status])
  @@index([tokenHash])
  @@index([organizationId, personnelId])
}

