generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  organizationId String @default("default-org")
  email        String   @unique
  passwordHash String
  role         String   @default("uploader")
  displayName  String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdDocuments  Document[] @relation("CreatedBy")
  uploadedDocuments Document[] @relation("UploadedBy")
  reviewedDocuments Document[] @relation("ReviewedBy")

  @@unique([organizationId, email])
  @@index([organizationId])
}

model Document {
  id                    String    @id
  organizationId        String    @default("default-org")
  programDomain         String    @default("community-chronicle")
  title                 String
  description           String    @default("")
  author                String    @default("Unknown")
  year                  Int
  month                 Int?
  category              String
  type                  String
  financialCategory     String?
  financialDocumentType String?
  tags                  Json
  keywords              Json
  originalFileName      String?
  mimeType              String?
  fileSize              Int?
  fileUrl               String
  filePath              String?
  processingStatus      String
  ocrStatus             String
  extractedText         String    @default("") @db.Text
  extractedMetadata     Json
  classificationResult  Json?
  intakeSource          String
  sourceReference       String?
  department            String?
  createdAt             DateTime
  updatedAt             DateTime  @updatedAt
  importedAt            DateTime
  processingHistory     Json
  status                String?
  statusUpdatedAt       DateTime?
  auditTrail            Json?
  extraction            Json?
  duplicateCheck        Json?
  review                Json?
  searchIndex           Json?
  needsReview           Boolean   @default(false)
  aiSummary             String    @default("") @db.Text

  createdByUserId String?
  uploadedById  String?
  reviewedById  String?
  createdBy     User?   @relation("CreatedBy", fields: [createdByUserId], references: [id])
  uploadedBy    User?   @relation("UploadedBy", fields: [uploadedById], references: [id])
  reviewedBy    User?   @relation("ReviewedBy", fields: [reviewedById], references: [id])

  jobs ProcessingJob[]

  @@index([organizationId, programDomain, createdAt])
  @@index([organizationId, programDomain, needsReview, updatedAt])
}

model ProcessingJob {
  id          String    @id @default(cuid())
  organizationId String @default("default-org")
  programDomain  String @default("community-chronicle")
  documentId  String
  status      String    @default("queued")
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  error       String?
  errorLog    Json?
  scheduledAt DateTime  @default(now())
  nextRetryAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([documentId])
  @@index([organizationId, programDomain, status, scheduledAt])
}
