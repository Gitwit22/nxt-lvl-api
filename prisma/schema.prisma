generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  organizationId String @default("default-org")
  email        String   @unique
  passwordHash String   @default("")
  role         String   @default("uploader")
  platformRole String   @default("user")      // "suite_admin" | "user"
  displayName  String   @default("")
  firstName    String   @default("")
  lastName     String   @default("")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mustChangePassword Boolean  @default(false)   // true after admin assigns a temp password
  passwordSetAt      DateTime?                  // set when user first chooses their own password

  // ── Deprecated / legacy platform-handoff fields ──────────────────────────
  // These were used by the old suite→app JWT handoff flow that has been removed.
  // Keep them nullable so existing rows are not broken; do not write new values.
  identitySource String  @default("local")   // @deprecated — was "platform" | "local"
  platformUserId String?                      // @deprecated — was Suite user ID for linked accounts
  // ─────────────────────────────────────────────────────────────────────────
  createdDocuments  Document[] @relation("CreatedBy")
  uploadedDocuments Document[] @relation("UploadedBy")
  reviewedDocuments Document[] @relation("ReviewedBy")
  memberships       Membership[] @relation("UserMembers")
  programAccess     UserProgramAccess[] @relation("UserProgramAccess")
  sentInvitations   OrgInvitation[] @relation("InvitedBy")

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([platformRole])
}

model Organization {
  id                String    @id @default(cuid())
  name              String
  // slug: canonical org identifier used in Suite URLs (/orgs/:slug)
  slug              String    @unique
  // subdomain: kept for legacy read compatibility; no longer used for routing
  // as all org access is via /orgs/:slug within the Suite shell.
  subdomain         String?
  contactEmail      String?
  ownerEmail        String?
  supportEmail      String?
  phoneNumber       String?
  industryType      String?
  notes             String?
  logoUrl           String?
  bannerUrl         String?
  // primaryColor / accentColor: org branding displayed in the workspace header.
  // These are decorative inside the Suite — no longer used to skin a separate shell.
  primaryColor      String?
  accentColor       String?
  // @deprecated — replaced by OrganizationProgramSubscription rows.
  // Kept nullable/readable for backfill reference; do not write new values.
  assignedBundleIds Json      @default("[]")
  assignedProgramIds Json     @default("[]")
  planType          String    @default("starter")
  // status: "active" | "pending" | "suspended" — enforced by OrgAccessGuard in the Suite
  status            String    @default("active")
  seatLimit         Int       @default(25)
  trialEndsAt       DateTime?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  members               Membership[]                      @relation("OrgMembers")
  programAccess         OrganizationProgramAccess[]        @relation("OrgProgramAccess")
  programSubscriptions  OrganizationProgramSubscription[]  @relation("OrgProgramSubscriptions")
  invitations           OrgInvitation[]                    @relation("OrgInvitations")
  storageSettings       ProgramStorageSettings[]

  @@index([isActive])
  @@index([status])
}

model ProgramStorageSettings {
  id             String   @id @default(cuid())
  organizationId String
  programDomain  String
  settings       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, programDomain])
  @@index([organizationId, programDomain])
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           String   @default("member")  // owner | admin | manager | member | viewer
  createdAt      DateTime @default(now())

  user         User         @relation("UserMembers", fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation("OrgMembers", fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([role])
}

model OrganizationProgramAccess {
  id             String   @id @default(cuid())
  organizationId String
  programId      String
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation("OrgProgramAccess", fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, programId])
  @@index([organizationId])
}

model UserProgramAccess {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  programId      String
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user    User    @relation("UserProgramAccess", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, programId])
  @@index([userId, organizationId])
}

model OrgInvitation {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  role           String    @default("member")
  invitedById    String
  token          String    @unique @default(cuid())
  status         String    @default("pending")  // pending | accepted | revoked | expired
  expiresAt      DateTime
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  invitedBy    User         @relation("InvitedBy", fields: [invitedById], references: [id])
  organization Organization @relation("OrgInvitations", fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email, status])
  @@index([organizationId, status])
  @@index([token])
}

// Subscription/entitlement: controls whether an org can launch a program.
// Replaces the old assignedProgramIds JSON blob on Organization.
// Platform admin manages these rows; app launch checks status === "active" | "trialing".
model OrganizationProgramSubscription {
  id                 String    @id @default(cuid())
  organizationId     String
  programId          String    // matches Program.id or a well-known slug like "mission-hub"
  status             String    @default("inactive")  // active | inactive | trialing | past_due | canceled
  subscriptionSource String    @default("manual")    // stripe | manual | comp
  startsAt           DateTime?
  endsAt             DateTime?
  seatLimit          Int?
  notes              String    @default("")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization Organization @relation("OrgProgramSubscriptions", fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, programId])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([status])
}

model Program {
  id               String   @id @default(cuid())
  programDomain    String
  organizationId   String?
  slug             String
  name             String
  shortDescription String
  longDescription  String   @default("")
  category         String   @default("General")
  tags             Json
  status           String
  type             String
  origin           String   @default("suite-native")
  internalRoute    String?
  externalUrl      String?
  openInNewTab     Boolean  @default(false)
  logoUrl          String?
  screenshotUrl    String?
  accentColor      String?
  isFeatured       Boolean  @default(false)
  isPublic         Boolean  @default(true)
  requiresLogin    Boolean  @default(false)
  requiresApproval Boolean  @default(false)
  launchLabel      String   @default("Launch")
  displayOrder     Int      @default(999)
  notes            String   @default("")
  // @deprecated — platform_only / hybrid modes removed; all programs use local auth
  authMode         String   @default("local_only")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  @@unique([programDomain, slug])
  @@index([programDomain, deletedAt, displayOrder])
  @@index([programDomain, organizationId])
}

// ─── Timeflow ─────────────────────────────────────────────────────────────────

model TimeflowSettings {
  id                    String   @id @default(cuid())
  organizationId        String
  userId                String
  businessName          String   @default("")
  defaultClientId       String?
  invoiceFrequency      String   @default("monthly")
  invoiceNotes          String   @default("")
  paymentInstructions   String   @default("")
  invoiceLogoDataUrl    String?  @db.Text
  invoiceBannerDataUrl  String?  @db.Text
  companyViewerAccess   Boolean  @default(false)
  emailTemplate         String   @default("") @db.Text
  periodWeekStartsOn    Int      @default(1)
  periodTargetHours     Float    @default(0)
  periodTargetEarnings  Float    @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([organizationId, userId])
  @@index([organizationId, userId])
}

model TimeflowClient {
  id                   String   @id @default(cuid())
  organizationId       String
  userId               String
  name                 String
  contactName          String?
  contactEmail         String?
  contacts             Json     @default("[]")
  hourlyRate           Float?
  companyViewerEnabled Boolean  @default(false)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  projects    TimeflowProject[]    @relation("ClientProjects")
  timeEntries TimeflowTimeEntry[]  @relation("ClientTimeEntries")

  @@index([organizationId, userId])
  @@index([organizationId, userId, isActive])
}

model TimeflowProject {
  id           String   @id @default(cuid())
  organizationId String
  userId       String
  clientId     String
  name         String
  status       String   @default("active")   // planning|active|on_hold|completed|archived
  description  String   @default("") @db.Text
  billingType  String   @default("hourly_uncapped")  // hourly_uncapped|hourly_capped|fixed_fee
  hourlyRate   Float    @default(0)
  maxPayoutCap Float    @default(0)
  capHandling  String   @default("allow_overage")    // allow_overage|warn_only|block_billable
  startDate    String
  endDate      String?
  notes        String   @default("") @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client      TimeflowClient      @relation("ClientProjects", fields: [clientId], references: [id], onDelete: Cascade)
  timeEntries TimeflowTimeEntry[] @relation("ProjectTimeEntries")

  @@index([organizationId, userId])
  @@index([organizationId, userId, clientId])
  @@index([organizationId, userId, status])
}

model TimeflowTimeEntry {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  clientId       String
  projectId      String?
  date           String
  startTime      String
  endTime        String?
  durationHours  Float    @default(0)
  billingRate    Float?
  billable       Boolean  @default(true)
  invoiced       Boolean  @default(false)
  invoiceId      String?
  notes          String   @default("")
  status         String   @default("completed")  // running|completed|invoiced
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client  TimeflowClient   @relation("ClientTimeEntries", fields: [clientId], references: [id], onDelete: Cascade)
  project TimeflowProject? @relation("ProjectTimeEntries", fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId, userId])
  @@index([organizationId, userId, clientId])
  @@index([organizationId, userId, date])
  @@index([organizationId, userId, invoiced])
  @@index([organizationId, userId, status])
}

model TimeflowInvoice {
  id            String   @id @default(cuid())
  organizationId String
  userId        String
  clientId      String
  periodStart   String
  periodEnd     String
  billingMode   String   @default("outstanding")  // range|outstanding
  rangeStart    String?
  rangeEnd      String?
  grouping      String   @default("none")          // none|day|week
  dueDate       String
  entryIds      Json     @default("[]")
  timeEntryIds  Json     @default("[]")
  lineItems     Json     @default("[]")
  projectIds    Json     @default("[]")
  totalHours    Float    @default(0)
  hourlyRate    Float    @default(0)
  subtotal      Float    @default(0)
  taxRate       Float    @default(0)
  taxAmount     Float    @default(0)
  totalAmount   Float    @default(0)
  hasMixedRates Boolean  @default(false)
  status        String   @default("draft")   // draft|issued|sent|paid
  issuedAt      DateTime?
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([organizationId, userId])
  @@index([organizationId, userId, clientId])
  @@index([organizationId, userId, status])
}

// ─── End Timeflow ──────────────────────────────────────────────────────────────

// ─── Mission Hub ──────────────────────────────────────────────────────────────

model MissionHubProgram {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String
  name            String
  category        String   @default("")
  manager         String   @default("")
  status          String   @default("Active")   // Active|Completed|Planning|Suspended
  startDate       String   @default("")
  endDate         String?
  budget          String   @default("")
  budgetAmount    Float    @default(0)
  progress        Int      @default(0)
  description     String   @default("") @db.Text
  targetAudience  String   @default("")
  team            Json     @default("[]")
  timeEntries     Json     @default("[]")
  budgetItems     Json     @default("[]")
  supporters      Json     @default("[]")
  sponsors        Json     @default("[]")
  documents       Json     @default("[]")
  tasks           Json     @default("[]")
  outcomes        Json     @default("[]")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId, userId])
  @@index([organizationId, userId, status])
}

model MissionHubProject {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  programDomain  String   @default("mission-hub")
  programId      String?
  name           String
  description    String   @default("") @db.Text
  status         String   @default("active") // active|paused|completed|archived
  managerId      String?
  managerName    String?
  grantId        String?
  grantName      String?
  sponsorId      String?
  sponsorName    String?
  fundraisingCampaignId String?
  budget         Float    @default(0)
  startDate      String?
  endDate        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, userId, programDomain])
  @@index([organizationId, userId, programDomain, status])
  @@index([organizationId, userId, programDomain, programId])
  @@index([organizationId, userId, programDomain, fundraisingCampaignId])
}

model MissionHubEvent {
  id                    String   @id @default(cuid())
  organizationId        String
  userId                String
  programDomain         String   @default("mission-hub")
  programId             String?
  projectId             String?
  grantId               String?
  sponsorId             String?
  fundraisingCampaignId String?
  name                  String
  description           String   @default("") @db.Text
  eventType             String?
  status                String   @default("planned") // planned|scheduled|active|completed|cancelled|archived
  startDateTime         String
  endDateTime           String
  location              String?
  isVirtual             Boolean  @default(false)
  meetingUrl            String?
  calendarEventId       String?
  assignedStaffIds      Json     @default("[]")
  assignedVolunteerIds  Json     @default("[]")
  budget                Float    @default(0)
  expectedRevenue       Float    @default(0)
  actualRevenue         Float    @default(0)
  billable              Boolean  @default(false)
  billingCode           String?
  fundingSourceType     String?  // grant|sponsor|fundraiser|program|general|mixed
  fundingSourceId       String?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([organizationId, userId, programDomain])
  @@index([organizationId, userId, programDomain, status])
  @@index([organizationId, userId, programDomain, programId])
  @@index([organizationId, userId, programDomain, projectId])
  @@index([organizationId, userId, programDomain, startDateTime])
}

model MissionHubGrant {
  id                 String   @id @default(cuid())
  organizationId     String
  userId             String
  grantName          String
  fundingSource      String   @default("")
  amountAwarded      Float    @default(0)
  startDate          String   @default("")
  endDate            String?
  status             String   @default("Active")
  grantManager       String   @default("")
  linkedPrograms     Json     @default("[]")
  reportingStatus    String   @default("")
  requirements       Json     @default("[]")
  budgetAllocation   Json     @default("[]")
  reportingDeadlines Json     @default("[]")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([organizationId, userId])
  @@index([organizationId, userId, status])
}

model MissionHubExpense {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String
  expenseName     String
  amount          Float    @default(0)
  date            String   @default("")
  category        String   @default("")
  customCategory  String?
  type            String   @default("")
  expenseScope    String?
  customExpenseScope String?
  linkedProgramId String?
  linkedProgram   String?
  linkedProjectId String?
  linkedProject   String?
  linkedEventId   String?
  linkedEvent     String?
  linkedGrantId   String?
  linkedGrant     String?
  linkedSponsorId String?
  linkedSponsor   String?
  linkedFundraisingCampaignId String?
  linkedFundraisingCampaign   String?
  linkedCampaign  String?  // legacy alias for linkedFundraisingCampaign
  fundingSourceType String?
  fundingSourceId   String?
  customFundingSource String?
  fundingSource   String?
  billable        Boolean  @default(false)
  reimbursable    Boolean  @default(false)
  notes           String   @default("")
  approvalStatus  String   @default("Pending")   // Pending|Approved|Rejected|Draft
  recurring       Boolean  @default(false)
  receiptFileId   String?
  receiptUrl      String?
  receiptName     String?
  receiptFileMeta Json?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId, userId])
  @@index([organizationId, userId, category])
  @@index([organizationId, userId, approvalStatus])
  @@index([organizationId, userId, linkedProjectId])
  @@index([organizationId, userId, linkedEventId])
  @@index([organizationId, userId, linkedGrantId])
  @@index([organizationId, userId, linkedSponsorId])
  @@index([organizationId, userId, linkedFundraisingCampaignId])
}

model MissionHubSponsor {
  id                 String   @id @default(cuid())
  organizationId     String
  userId             String
  sponsorType        String   @default("")
  organizationName   String
  contactName        String   @default("")
  email              String   @default("")
  phone              String   @default("")
  contributionAmount Float    @default(0)
  contributionType   String   @default("")
  paymentStatus      String   @default("")
  status             String   @default("Active")
  notes              String   @default("")
  linkedPrograms     Json     @default("[]")
  linkedCampaigns    Json     @default("[]")
  linkedItems        Json     @default("[]")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([organizationId, userId])
  @@index([organizationId, userId, status])
}

model MissionHubCampaign {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  name           String
  category       String   @default("Event")    // Event|Drive|Seasonal|Equipment
  status         String   @default("Planning") // Planning|Active|Closed
  owner          String   @default("")
  startDate      String   @default("")
  endDate        String?
  goalAmount     Float    @default(0)
  linkedPrograms Json     @default("[]")
  tiers          Json     @default("[]")
  items          Json     @default("[]")
  donations      Json     @default("[]")
  events         Json     @default("[]")
  expenses       Json     @default("[]")
  documents      Json     @default("[]")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, userId])
  @@index([organizationId, userId, status])
}

model MissionHubPersonnel {
  id               String   @id @default(cuid())
  organizationId   String
  userId           String
  firstName        String
  lastName         String
  email            String   @default("")
  phone            String   @default("")
  title            String   @default("")
  department       String   @default("")
  type             String   @default("Staff")  // Staff|Volunteer|Contractor|Board Member
  role             String   @default("Admin")  // Executive Director|Deputy Director|Finance|Admin
  status           String   @default("Active") // Active|Inactive|On Leave
  accessLevel      String   @default("Basic")  // Full|Operational|Financial|Basic
  assignedPrograms Json     @default("[]")
  assignedGrants   Json     @default("[]")
  notes            String   @default("")
  inviteStatus     String   @default("none")
  // "none" | "invite_created" | "invite_pending" | "accepted" | "revoked"
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([organizationId, userId])
  @@index([organizationId, userId, status])
  @@index([organizationId, userId, type])
}

model MissionHubInvite {
  id               String    @id @default(cuid())
  organizationId   String
  personnelId      String    @unique
  recipientEmail   String
  recipientName    String
  assignedRole     String
  assignedPosition String    @default("")
  createdByAdminId String
