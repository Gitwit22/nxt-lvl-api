  linkedFundraisingCampaignId String?
  linkedFundraisingCampaign   String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId, userId, programDomain])
  @@index([organizationId, userId, programDomain, status])
  @@index([organizationId, userId, programDomain, dueDate])
  @@index([organizationId, userId, programDomain, linkedProjectId])
  @@index([organizationId, userId, programDomain, assignedPersonId])
}

model MissionHubTimeEntry {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  programDomain  String   @default("mission-hub")
  personId       String?
  person         String
  initials       String   @default("")
  date           String
  startTime      String   @default("")
  endTime        String   @default("")
  hours          Float    @default(0)
  programId      String?
  projectId      String?
  projectName    String?
  grantId        String?
  sponsorId      String?
  fundraisingCampaignId String?
  fundingSourceType String?
  fundingSourceId String?
  linkedGrant    String?
  linkedSponsor  String?
  eventId        String?
  eventName      String?
  timesheetSubmissionId String?
  billable       Boolean  @default(false)
  payable        Boolean  @default(false)
  volunteer      Boolean  @default(false)
  hourlyRate     Float?
  laborValue     Float?
  notes          String   @default("")
  status         String   @default("draft")
  submittedAt    DateTime?
  approvedAt     DateTime?
  processedAt    DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, userId, programDomain])
  @@index([organizationId, userId, programDomain, status])
  @@index([organizationId, userId, programDomain, date])
  @@index([organizationId, programDomain, timesheetSubmissionId])
}

model MissionHubTimesheetSubmission {
  id                     String   @id @default(cuid())
  organizationId         String
  programDomain          String   @default("mission-hub")
  submittedByPersonId    String?
  submittedByUserId      String
  periodStart            String
  periodEnd              String
  status                 String   @default("draft")
  totalHours             Float    @default(0)
  payableHours           Float    @default(0)
  volunteerHours         Float    @default(0)
  billableHours          Float    @default(0)
  estimatedPayableAmount Float    @default(0)
  estimatedBillableAmount Float   @default(0)
  grantLaborValue        Float?
  volunteerMatchValue    Float?
  submittedAt            DateTime?
  reviewedByUserId       String?
  reviewedAt             DateTime?
  financeNotes           String?
  rejectionReason        String?
  changeRequestReason    String?
  processedAt            DateTime?
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([organizationId, programDomain])
  @@index([organizationId, programDomain, status])
  @@index([organizationId, submittedByUserId, programDomain])
}

model MissionHubTimesheetApprovalLog {
  id                    String   @id @default(cuid())
  organizationId        String
  programDomain         String   @default("mission-hub")
  timesheetSubmissionId String
  action                String
  actorUserId           String
  actorPersonId         String?
  actorRole             String?
  note                  String?
  createdAt             DateTime @default(now())

  @@index([organizationId, programDomain, timesheetSubmissionId, createdAt])
  @@index([organizationId, actorUserId, programDomain])
}

model MissionHubDocument {
  id               String   @id @default(cuid())
  organizationId   String
  programDomain    String   @default("mission-hub")
  uploaderUserId   String
  title            String
  originalFilename String   @default("")
  mimeType         String   @default("")
  sizeBytes        Int      @default(0)
  storageKey       String   @default("")
  storageBucket    String   @default("")
  storageProvider  String   @default("r2")  // r2|local|external
  linkedEntityType String?  // program|project|event|grant|sponsor|campaign|expense|personnel
  linkedEntityId   String?
  tags             Json     @default("[]")
  metadata         Json     @default("{}")
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([organizationId, programDomain])
  @@index([organizationId, programDomain, linkedEntityType, linkedEntityId])
  @@index([organizationId, programDomain, uploaderUserId])
}

model MissionHubStorageEndpoint {
  id             String   @id @default(cuid())
  organizationId String
  programDomain  String   @default("mission-hub")
  name           String
  provider       String   @default("r2")  // r2|local_server_storage|shared_file_system|external
  bucketOrBinding String  @default("")    // bucket name or Cloudflare binding name
  basePrefix     String   @default("")
  enabled        Boolean  @default(true)
  isDefault      Boolean  @default(false)
  config         Json     @default("{}")  // non-secret provider settings (region, endpoint URL, etc.)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, programDomain, name])
  @@index([organizationId, programDomain])
  @@index([organizationId, programDomain, enabled])
}

model MissionHubOrganizationSettings {
  id              String   @id @default(cuid())
  organizationId  String   @unique
  orgDisplayName  String   @default("")
  fiscalYearStart String   @default("01-01") // MM-DD format
  defaultTimezone String   @default("America/New_York")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
}

model MissionHubScheduledReport {
  id             String   @id @default(cuid())
  organizationId String
  createdByUserId String
  name           String
  reportType     String   @default("")
  schedule       String   @default("weekly")  // daily|weekly|monthly|quarterly
  recipients     Json     @default("[]")       // string[] of email addresses
  filters        Json     @default("{}")
  isActive       Boolean  @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([nextRunAt])
}

// ─── End Mission Hub ──────────────────────────────────────────────────────────

model Document {
  id                    String    @id
  organizationId        String
  programDomain         String
  parentDocumentId      String?
  rootDocumentId        String?
  isVirtualSegment      Boolean   @default(false)
  segmentIndex          Int?
  segmentPageStart      Int?
  segmentPageEnd        Int?
  segmentConfidence     Float?
  splitReviewRequired   Boolean   @default(false)
  segmentationStatus    String?
  title                 String
  description           String    @default("")
  author                String    @default("Unknown")
  year                  Int
  month                 Int?
  category              String
  type                  String
  financialCategory     String?
  financialDocumentType String?
  tags                  Json
  keywords              Json
  originalFileName      String?
  mimeType              String?
  fileSize              Int?
  fileUrl               String
  filePath              String?
  processingStatus      String
  ocrStatus             String
  extractedText         String    @default("") @db.Text
  extractedMetadata     Json
  classificationResult  Json?
  intakeSource          String
  sourceReference       String?
  department            String?
  createdAt             DateTime
  updatedAt             DateTime  @updatedAt
  importedAt            DateTime
  processingHistory     Json
  status                String?
  statusUpdatedAt       DateTime?
  auditTrail            Json?
  extraction            Json?
  duplicateCheck        Json?
  review                Json?
  searchIndex           Json?
  needsReview           Boolean   @default(false)
  aiSummary             String    @default("") @db.Text

  // ── Lightweight search-first metadata (Phase 2 refactor) ─────────────────
  // documentType: canonical type key (invoice | receipt | letter | form |
  //   sign_in_sheet | business_card | report | notice | other_unclassified | custom)
  documentType          String?
  // sourceName: who issued / sent the document (org name, person, agency)
  sourceName            String?
  // documentDate: ISO date string extracted from document content
  documentDate          String?
  // Structured entity arrays extracted from document text
  metaPeople            Json?     // string[]
  metaCompanies         Json?     // string[]
  metaLocations         Json?     // string[]
  metaReferenceNumbers  Json?     // string[]
  metaOther             Json?     // string[] — anything useful that doesn't fit buckets
  // classificationStatus: known | other_unclassified | reviewed_mapped | promoted_custom_type
  classificationStatus  String?
  // classificationMatchedBy: rule | keyword | source | similarity | manual
  classificationMatchedBy String?
  // classificationConfidence: 0–1 float
  classificationConfidence Float?
  // reviewRequired: true when type is other_unclassified or confidence is low
  reviewRequired        Boolean   @default(false)

  createdByUserId String?
  uploadedById  String?
  reviewedById  String?
  parentDocument Document? @relation("DocumentSegments", fields: [parentDocumentId], references: [id], onDelete: SetNull)
  childSegments  Document[] @relation("DocumentSegments")
  createdBy     User?   @relation("CreatedBy", fields: [createdByUserId], references: [id])
  uploadedBy    User?   @relation("UploadedBy", fields: [uploadedById], references: [id])
  reviewedBy    User?   @relation("ReviewedBy", fields: [reviewedById], references: [id])

  jobs ProcessingJob[]
  pageFeatures ChroniclePdfPageFeature[]
  boundaryDecisions ChroniclePdfBoundaryDecision[]

  @@index([organizationId, programDomain, createdAt])
  @@index([organizationId, programDomain, needsReview, updatedAt])
  @@index([organizationId, programDomain, documentType])
  @@index([organizationId, programDomain, classificationStatus])
  @@index([organizationId, programDomain, reviewRequired, updatedAt])
  @@index([organizationId, programDomain, parentDocumentId])
  @@index([organizationId, programDomain, rootDocumentId])
  @@index([organizationId, programDomain, splitReviewRequired, updatedAt])
}

// ── Community Chronicle: document type registry ───────────────────────────────
// Stores both system-defined and admin-created document types.
model ChronicleDocumentType {
  id            String    @id @default(cuid())
  organizationId String
  programDomain  String   @default("community-chronicle")
  key           String    // e.g. "invoice", "receipt", "my_custom_type"
  label         String    // Human-readable label
  description   String    @default("")
  isSystemType  Boolean   @default(false)  // true = shipped with the system
  isUserCreated Boolean   @default(false)  // true = admin promoted from other_unclassified
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  fingerprint   ChronicleTypeFingerprint?

  @@unique([organizationId, programDomain, key])
  @@index([organizationId, programDomain, active])
}

// ── Community Chronicle: type fingerprints for learned classification ─────────
// Stores phrases, company names, and patterns discovered during admin review
// of other_unclassified documents.  Used to improve future classifications.
model ChronicleTypeFingerprint {
  id             String   @id @default(cuid())
  documentTypeId String   @unique
  phrases        Json     @default("[]")   // string[] — distinctive phrases
  companies      Json     @default("[]")   // string[] — known issuers
  filenamePatterns Json   @default("[]")   // string[] — filename regex patterns
  datePatterns   Json     @default("[]")   // string[] — date format hints
  sampleDocumentIds Json  @default("[]")   // string[] — doc IDs used as examples
  updatedAt      DateTime @updatedAt

  documentType ChronicleDocumentType @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)
}

model ProcessingJob {
  id             String    @id @default(cuid())
  organizationId String
  programDomain  String
  documentId  String
  status      String    @default("queued")
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  error       String?
  errorLog    Json?
  scheduledAt DateTime  @default(now())
  nextRetryAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([documentId])
  @@index([organizationId, programDomain, status, scheduledAt])
}

model ChroniclePdfPageFeature {
  id               String   @id @default(cuid())
  organizationId   String
  programDomain    String
  documentId       String
  pageIndex        Int
  topLines         Json     @default("[]")
  bottomLines      Json     @default("[]")
  headerTitle      String?
  identifierTokens Json     @default("[]")
  pageNumberCue    Json?
  templateSignature String?
  layoutHints      Json     @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, pageIndex])
  @@index([organizationId, programDomain, documentId])
}

model ChroniclePdfBoundaryDecision {
  id                String   @id @default(cuid())
  organizationId    String
  programDomain     String
  documentId        String
  leftPageIndex     Int
  rightPageIndex    Int
  continuationScore Float
  boundaryScore     Float
  confidence        Float
  decision          String
  reasons           Json     @default("[]")
  evidence          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, leftPageIndex, rightPageIndex])
  @@index([organizationId, programDomain, documentId])
}
